model Session {
  id            Int      @id @default(autoincrement())
  providerId    String
  marketId      String
  name          String

  backPrice     Float?
  layPrice      Float?
  backSize      Float?
  laySize       Float?

  mname         String?
  gtype         String?
  sortPriority  Int?
  providerTs    BigInt?

  eventId       Int
  event         Event    @relation(fields: [eventId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([providerId, eventId])
}

